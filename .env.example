# Docker Compose: app в сети db → Postgres на localhost контейнера
DATABASE_URL=postgresql+asyncpg://app:app@127.0.0.1:5432/app?ssl=disable

# Секрет для JWT (рекомендуется ≥ 32 байта для HS256)
SECRET_KEY=change-me-to-a-long-random-secret-at-least-32-chars

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Логи: json (docker) или console (локально)
LOG_FORMAT=json
